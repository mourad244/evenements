# JWT Secrets
# These secrets should be at least 32 characters long. Use `openssl rand -hex 32` to generate secure keys for production.
JWT_ACCESS_SECRET=your_production_access_secret_here
JWT_REFRESH_SECRET=your_production_refresh_secret_here

# SMTP Configuration (for password reset emails)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_user
# SMTP_PASS=your_pass
# SMTP_FROM="Event Platform" <noreply@eventplatform.local>

# Frontend URL
FRONTEND_URL=https://your-production-url.com
